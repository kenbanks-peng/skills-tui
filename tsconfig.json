{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/react",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"#components/*": ["./src/components/*"],
			"#hooks/*": ["./src/hooks/*"],
			"#lib/*": ["./src/lib/*"],
			"#services/*": ["./src/services/*"]
		}
	},
	"include": ["src"]
}
